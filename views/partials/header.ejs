<header class="header" style="background-color: #003366;">
  <nav class="navbar navbar-expand-lg">
    <div class="container-fluid">
      <!-- Logo/Brand -->
      <a class="navbar-brand text-white" href="/">
        <h2 class="mb-0 fw-bold">Notify</h2>
      </a>

      <!-- Navigation Links -->
      <ul class="nav d-none d-md-flex mx-auto">
        <li class="nav-item"><a href="/" class="nav-link px-3 text-white">Home</a></li>
        <li class="nav-item"><a href="/features" class="nav-link px-3 text-white">Features</a></li>
        <li class="nav-item"><a href="/about" class="nav-link px-3 text-white">About</a></li>
        <% if (user) { %>
          <li class="nav-item"><a href="/dashboard" class="nav-link px-3 text-white">Dashboard</a></li>
        <% } %>
      </ul>

      <!-- Buttons (Right Side) -->
      <div class="d-flex gap-2 ms-auto">
        <% if (user) { %>
          <a href="/dashboard/add" class="btn btn-light">+ New Note</a>
          <a href="/logout" class="btn btn-outline-light">Logout</a>
        <% } else { %>
          <a href="/auth/google" class="btn btn-outline-light">Sign Up</a>
          <a href="/auth/google" class="btn btn-light">Sign In</a>
        <% } %>
      </div>
    </div>
  </nav>
</header>